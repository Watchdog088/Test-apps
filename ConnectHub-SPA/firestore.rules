// firestore.rules — ConnectHub / LynkApp
// SECTION-8 UPDATE: Block enforcement rules added
// Users cannot read posts/profiles/stories from accounts they have blocked or that have blocked them

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    // BLOCK ENFORCEMENT: check if caller blocked target OR target blocked caller
    function notBlocked(targetUid) {
      return isAuth() &&
        !exists(/databases/$(database)/documents/blocks/$(request.auth.uid + '_' + targetUid)) &&
        !exists(/databases/$(database)/documents/blocks/$(targetUid + '_' + request.auth.uid));
    }
    // Private account check — caller must follow targetUid or be targetUid
    function canViewPrivate(ownerUid) {
      return isOwner(ownerUid) ||
        isAdmin() ||
        exists(/databases/$(database)/documents/follows/$(request.auth.uid + '_' + ownerUid));
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth() && notBlocked(uid);
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Posts ─────────────────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if isAuth() &&
        notBlocked(resource.data.userId) &&
        (
          !get(/databases/$(database)/documents/users/$(resource.data.userId)).data.get('isPrivate', false)
          || canViewPrivate(resource.data.userId)
        );
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ── Follows ───────────────────────────────────────────────────────────────
    match /follows/{followId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.followerId == request.auth.uid
        && notBlocked(request.resource.data.followeeId);
      allow delete: if isAuth() && resource.data.followerId == request.auth.uid;
    }

    // ── Follow Requests (private accounts) ───────────────────────────────────
    match /followRequests/{reqId} {
      allow read: if isAuth() && (
        resource.data.requestorId == request.auth.uid ||
        resource.data.targetId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuth() && request.resource.data.requestorId == request.auth.uid
        && notBlocked(request.resource.data.targetId);
      allow update: if isAuth() && resource.data.targetId == request.auth.uid;
      allow delete: if isAuth() && (
        resource.data.requestorId == request.auth.uid ||
        resource.data.targetId == request.auth.uid
      );
    }

    // ── Blocks ────────────────────────────────────────────────────────────────
    match /blocks/{blockId} {
      allow read: if isAuth() && (
        resource.data.blockerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuth() && request.resource.data.blockerId == request.auth.uid;
      allow delete: if isAuth() && resource.data.blockerId == request.auth.uid;
    }

    // ── Reports ───────────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuth() && request.resource.data.reporterId == request.auth.uid;
      allow update: if isAdmin();
    }

    // ── Stories ───────────────────────────────────────────────────────────────
    match /stories/{storyId} {
      allow read: if isAuth() &&
        notBlocked(resource.data.userId) &&
        (
          !get(/databases/$(database)/documents/users/$(resource.data.userId)).data.get('isPrivate', false)
          || canViewPrivate(resource.data.userId)
        );
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ── Messages / Conversations ──────────────────────────────────────────────
    match /conversations/{convId} {
      allow read, write: if isAuth() && request.auth.uid in resource.data.participants;
    }
    match /messages/{msgId} {
      allow read: if isAuth() && request.auth.uid in
        get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participants;
      allow create: if isAuth() && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.senderId) || isAdmin();
    }

    // ── Verification Requests ─────────────────────────────────────────────────
    match /verificationRequests/{reqId} {
      allow read: if isAdmin() || isOwner(resource.data.uid);
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/verificationRequests/$(request.auth.uid));
      allow update: if isAdmin();
    }

    // ── Analytics ─────────────────────────────────────────────────────────────
    match /analytics/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isAdmin();
    }

    // ── Clips ─────────────────────────────────────────────────────────────────
    match /clips/{clipId} {
      allow read: if isAuth() && notBlocked(resource.data.userId);
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ── Default deny ──────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
