// firestore.rules — LynkApp / ConnectHub
// Complete production rules covering all 12 app sections
// Last updated: May 28, 2026

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    // BLOCK ENFORCEMENT: check if caller blocked target OR target blocked caller
    function notBlocked(targetUid) {
      return isAuth() &&
        !exists(/databases/$(database)/documents/blocks/$(request.auth.uid + '_' + targetUid)) &&
        !exists(/databases/$(database)/documents/blocks/$(targetUid + '_' + request.auth.uid));
    }
    // Private account check — caller must follow targetUid or be targetUid
    function canViewPrivate(ownerUid) {
      return isOwner(ownerUid) ||
        isAdmin() ||
        exists(/databases/$(database)/documents/follows/$(request.auth.uid + '_' + ownerUid));
    }
    // Check if user is a member of a group
    function isGroupMember(groupId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/groupMembers/$(groupId + '_' + request.auth.uid));
    }
    // Check if user is a group admin/moderator
    function isGroupAdmin(groupId) {
      return isAuth() &&
        get(/databases/$(database)/documents/groupMembers/$(groupId + '_' + request.auth.uid)).data.role in ['admin', 'moderator'];
    }


    // ══════════════════════════════════════════════════════════════════════════
    // SECTION 1 — USERS & PROFILES
    // ══════════════════════════════════════════════════════════════════════════

    match /users/{uid} {
      allow read: if isAuth() && notBlocked(uid);
      allow create: if isOwner(uid)
        // On create, user CANNOT self-assign admin/moderator role
        && !('role' in request.resource.data);
      // Users can update their OWN profile BUT cannot touch role, isAdmin, or isModerator fields
      allow update: if isOwner(uid)
        && !('role' in request.resource.data)
        && !('isAdmin' in request.resource.data)
        && !('isModerator' in request.resource.data);
      // Only admins can promote/demote roles or delete accounts
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /userSettings/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /onboardingStatus/{uid} {
      allow read, write: if isOwner(uid);
    }


    // ══════════════════════════════════════════════════════════════════════════
    // SECTION 2 — FEED, POSTS, INTERACTIONS
    // ══════════════════════════════════════════════════════════════════════════

    match /posts/{postId} {
      allow read: if isAuth() &&
        notBlocked(resource.data.userId) &&
        (
          !get(/databases/$(database)/documents/users/$(resource.data.userId)).data.get('isPrivate', false)
          || canViewPrivate(resource.data.userId)
        );
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /likes/{likeId} {
      // likeId format: userId_postId
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    match /comments/{commentId} {
      allow read: if isAuth() && notBlocked(resource.data.userId);
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /savedPosts/{docId} {
      // docId format: userId_postId
      allow read, write: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    match /postViews/{docId} {
      allow read: if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    match /shares/{shareId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }


    // ══════════════════════════════════════════════════════════════════════════
    // SECTION 3 — STORIES
    // ══════════════════════════════════════════════════════════════════════════

    match /stories/{storyId} {
      allow read: if isAuth() &&
        notBlocked(resource.data.userId) &&
        (
          !get(/databases/$(database)/documents/users/$(resource.data.userId)).data.get('isPrivate', false)
          || canViewPrivate(resource.data.userId)
        );
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /storyViews/{docId} {
      allow read: if isAuth() && (resource.data.viewerId == request.auth.uid || resource.data.storyOwnerId == request.auth.uid);
      allow create: if isAuth() && request.resource.data.viewerId == request.auth.uid;
    }

    match /storyReactions/{docId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    match /storyHighlights/{highlightId} {
      allow read: if isAuth() && notBlocked(resource.data.userId);
      allow write: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow delete: if isOwner(resource.data.userId);
    }


    // ══════════════════════════════════════════════════════════════════════════
    // SECTION 4 — LIVE STREAMING
    // ══════════════════════════════════════════════════════════════════════════

    match /livestreams/{streamId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.hostId == request.auth.uid;
      allow update: if isAuth() && (resource.data.hostId == request.auth.uid || isAdmin());
      allow delete: if isAuth() && (resource.data.hostId == request.auth.uid || isAdmin());
    }

    match /liveViewers/{docId} {
      allow read: if isAuth();
      allow create, update: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    match /liveGifts/{giftId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.senderId == request.auth.uid;
    }

    match /liveComments/{commentId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /clips/{clipId} {
      allow read: if isAuth() && notBlocked(resource.data.userId);
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /liveSchedule/{scheduleId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.hostId == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.hostId == request.auth.uid;
    }


    // ══════════════════════════════════════════════════════════════════════════
    // SECTION 5 — DATING
    // ══════════════════════════════════════════════════════════════════════════

    match /datingProfiles/{uid} {
      // Only show to auth'd users who have not blocked / been blocked
      allow read: if isAuth() && notBlocked(uid);
      allow create, update: if isOwner(uid);
      allow delete: if isOwner(uid) || isAdmin();
    }

    match /swipes/{swipeId} {
      // swipeId format: swiperId_swipedId
      allow read: if isAuth() && (
        resource.data.swiperId == request.auth.uid ||
        resource.data.swipedId == request.auth.uid
      );
      allow create: if isAuth() && request.resource.data.swiperId == request.auth.uid
        && notBlocked(request.resource.data.swipedId);
    }

    match /matches/{matchId} {
      allow read: if isAuth() && request.auth.uid in resource.data.users;
      allow create: if isAdmin(); // matches created by Cloud Function only
      allow update: if isAuth() && request.auth.uid in resource.data.users;
      allow delete: if isAdmin();
    }

    match /datingPreferences/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /speedDatingSessions/{sessionId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.hostId == request.auth.uid;
      allow update: if isAuth() && (resource.data.hostId == request.auth.uid || isAdmin());
    }

    // dating_swipes — written by client, read by Cloud Function & owner
    match /dating_swipes/{swipeId} {
      allow read: if isAuth() && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toUid   == request.auth.uid
      );
      allow create: if isAuth() && request.resource.data.fromUid == request.auth.uid
        && notBlocked(request.resource.data.toUid);
      allow delete: if isAuth() && resource.data.fromUid == request.auth.uid;
    }

    // dating_matches — created by onSwipeCreate Cloud Function (admin SDK bypasses rules)
    match /dating_matches/{matchId} {
      allow read:   if isAuth() && request.auth.uid in resource.data.users;
      allow create: if isAdmin(); // Cloud Function only
      allow update: if isAuth() && request.auth.uid in resource.data.users;
      allow delete: if isAdmin();
    }


    // ══════════════════════════════════════════════════════════════════════════
    // SECTION 6 — MESSAGES
    // ══════════════════════════════════════════════════════════════════════════

    match /conversations/{convId} {
      allow read: if isAuth() && request.auth.uid in resource.data.participants;
      allow create: if isAuth() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuth() && request.auth.uid in resource.data.participants;
      allow delete: if isAdmin();
    }

    match /messages/{msgId} {
      allow read: if isAuth() && request.auth.uid in
        get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participants;
      allow create: if isAuth() && request.resource.data.senderId == request.auth.uid;
      allow update: if isOwner(resource.data.senderId) || isAdmin();
      allow delete: if isOwner(resource.data.senderId) || isAdmin();
    }

    match /messageRequests/{reqId} {
      allow read: if isAuth() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
      allow create: if isAuth() && request.resource.data.senderId == request.auth.uid
        && notBlocked(request.resource.data.receiverId);
      allow update: if isAuth() && resource.data.receiverId == request.auth.uid;
      allow delete: if isAuth() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
    }


    // ══════════════════════════════════════════════════════════════════════════
    // SECTION 7 — NOTIFICATIONS
    // ══════════════════════════════════════════════════════════════════════════

    match /notifications/{notifId} {
      // Users can only read their own notifications
      allow read: if isAuth() && resource.data.recipientId == request.auth.uid;
      // Notifications created by Cloud Functions (admin) or the triggering user
      allow create: if isAuth() && (
        request.resource.data.recipientId != null &&
        (request.resource.data.senderId == request.auth.uid || isAdmin())
      );
      // Only the recipient can mark as read (update)
      allow update: if isAuth() && resource.data.recipientId == request.auth.uid;
      // Recipient can delete, admin can delete
      allow delete: if isAuth() && (resource.data.recipientId == request.auth.uid || isAdmin());
    }

    match /notificationSettings/{uid} {
      allow read, write: if isOwner(uid);
    }


    // ══════════════════════════════════════════════════════════════════════════
    // SECTION 8 — PROFILES (additional sub-features)
    // ══════════════════════════════════════════════════════════════════════════

    match /follows/{followId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.followerId == request.auth.uid
        && notBlocked(request.resource.data.followeeId);
      allow delete: if isAuth() && resource.data.followerId == request.auth.uid;
    }

    match /followRequests/{reqId} {
      allow read: if isAuth() && (
        resource.data.requestorId == request.auth.uid ||
        resource.data.targetId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuth() && request.resource.data.requestorId == request.auth.uid
        && notBlocked(request.resource.data.targetId);
      allow update: if isAuth() && resource.data.targetId == request.auth.uid;
      allow delete: if isAuth() && (
        resource.data.requestorId == request.auth.uid ||
        resource.data.targetId == request.auth.uid
      );
    }

    match /blocks/{blockId} {
      allow read: if isAuth() && (
        resource.data.blockerId == request.auth.uid || isAdmin()
      );
      allow create: if isAuth() && request.resource.data.blockerId == request.auth.uid;
      allow delete: if isAuth() && resource.data.blockerId == request.auth.uid;
    }

    match /verificationRequests/{reqId} {
      allow read: if isAdmin() || isOwner(resource.data.uid);
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/verificationRequests/$(request.auth.uid));
      allow update: if isAdmin();
    }

    match /profileInsights/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isAdmin(); // written by Cloud Functions only
    }


    // ══════════════════════════════════════════════════════════════════════════
    // SECTION 9 — FRIENDS
    // ══════════════════════════════════════════════════════════════════════════

    match /friendRequests/{reqId} {
      allow read: if isAuth() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
      allow create: if isAuth() && request.resource.data.senderId == request.auth.uid
        && notBlocked(request.resource.data.receiverId);
      allow update: if isAuth() && resource.data.receiverId == request.auth.uid;
      allow delete: if isAuth() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
    }

    match /friends/{docId} {
      // docId format: userId1_userId2 (sorted alphabetically)
      allow read: if isAuth() && (
        resource.data.user1 == request.auth.uid ||
        resource.data.user2 == request.auth.uid
      );
      allow create, delete: if isAuth() && (
        request.resource.data.user1 == request.auth.uid ||
        request.resource.data.user2 == request.auth.uid
      );
    }


    // ══════════════════════════════════════════════════════════════════════════
    // SECTION 10 — GROUPS
    // ══════════════════════════════════════════════════════════════════════════

    match /groups/{groupId} {
      // Public groups readable by all auth'd users, private groups only members
      allow read: if isAuth() && (
        resource.data.privacy == 'public' || isGroupMember(groupId) || isAdmin()
      );
      allow create: if isAuth() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isGroupAdmin(groupId) || isAdmin();
      allow delete: if isAdmin() ||
        (isAuth() && resource.data.creatorId == request.auth.uid);
    }

    match /groupMembers/{docId} {
      // docId format: groupId_userId
      allow read: if isAuth() && (
        isGroupMember(resource.data.groupId) || isAdmin()
      );
      allow create: if isAuth() && (
        // Joining a public group
        (request.resource.data.userId == request.auth.uid &&
         get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.privacy == 'public')
        || isGroupAdmin(resource.data.groupId)
        || isAdmin()
      );
      allow update: if isGroupAdmin(resource.data.groupId) || isAdmin();
      allow delete: if isAuth() && (
        resource.data.userId == request.auth.uid || // leaving
        isGroupAdmin(resource.data.groupId) ||      // kicked
        isAdmin()
      );
    }

    match /groupPosts/{postId} {
      allow read: if isAuth() && isGroupMember(resource.data.groupId);
      allow create: if isAuth() &&
        request.resource.data.userId == request.auth.uid &&
        isGroupMember(request.resource.data.groupId);
      allow update: if isAuth() && (
        resource.data.userId == request.auth.uid || isGroupAdmin(resource.data.groupId) || isAdmin()
      );
      allow delete: if isAuth() && (
        resource.data.userId == request.auth.uid || isGroupAdmin(resource.data.groupId) || isAdmin()
      );
    }

    match /groupJoinRequests/{reqId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        isGroupAdmin(resource.data.groupId) ||
        isAdmin()
      );
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isGroupAdmin(resource.data.groupId) || isAdmin();
      allow delete: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        isGroupAdmin(resource.data.groupId)
      );
    }


    // ══════════════════════════════════════════════════════════════════════════
    // SECTION 11 — EVENTS
    // ══════════════════════════════════════════════════════════════════════════

    match /events/{eventId} {
      // Public events visible to all auth'd users
      allow read: if isAuth() && (
        resource.data.visibility == 'public' ||
        resource.data.hostId == request.auth.uid ||
        request.auth.uid in resource.data.get('coHosts', []) ||
        isAdmin()
      );
      allow create: if isAuth() && request.resource.data.hostId == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.hostId == request.auth.uid ||
        request.auth.uid in resource.data.get('coHosts', []) ||
        isAdmin()
      );
      allow delete: if isAuth() && (resource.data.hostId == request.auth.uid || isAdmin());
    }

    match /eventAttendees/{docId} {
      // docId format: eventId_userId
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.hostId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.hostId == request.auth.uid ||
        isAdmin()
      );
    }


    // ══════════════════════════════════════════════════════════════════════════
    // SECTION 12 — MARKETPLACE
    // ══════════════════════════════════════════════════════════════════════════

    match /listings/{listingId} {
      // All auth'd users can browse listings
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isAuth() && (resource.data.sellerId == request.auth.uid || isAdmin());
      allow delete: if isAuth() && (resource.data.sellerId == request.auth.uid || isAdmin());
    }

    match /orders/{orderId} {
      // Only buyer and seller (and admin) can see an order
      allow read: if isAuth() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid ||
        isAdmin()
      );
      // Orders created via Stripe webhook Cloud Function (admin)
      allow create: if isAdmin() ||
        (isAuth() && request.resource.data.buyerId == request.auth.uid);
      allow update: if isAdmin() || (isAuth() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid
      ));
    }

    match /reviews/{reviewId} {
      allow read: if isAuth();
      // Only verified buyers can leave reviews
      allow create: if isAuth() && request.resource.data.reviewerId == request.auth.uid;
      allow update: if isAuth() && resource.data.reviewerId == request.auth.uid;
      allow delete: if isAuth() && (resource.data.reviewerId == request.auth.uid || isAdmin());
    }

    match /sellerProfiles/{uid} {
      allow read: if isAuth();
      allow create, update: if isOwner(uid);
      allow delete: if isAdmin();
    }

    match /kycSubmissions/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update: if isOwner(uid);
    }

    match /cart/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /wishlist/{docId} {
      allow read, write: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    match /shippingAddresses/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /disputes/{disputeId} {
      allow read: if isAdmin() || (isAuth() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid
      ));
      allow create: if isAuth() && (
        request.resource.data.buyerId == request.auth.uid ||
        request.resource.data.sellerId == request.auth.uid
      );
      allow update: if isAdmin();
    }


    // ══════════════════════════════════════════════════════════════════════════
    // REPORTS, ANALYTICS, MODERATION
    // ══════════════════════════════════════════════════════════════════════════

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuth() && request.resource.data.reporterId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /analytics/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isAdmin(); // written by Cloud Functions only
    }

    match /adminLogs/{logId} {
      allow read, write: if isAdmin();
    }

    match /appConfig/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }


    // ══════════════════════════════════════════════════════════════════════════
    // SEARCH & TRENDING
    // ══════════════════════════════════════════════════════════════════════════

    match /searchIndex/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin(); // maintained by Cloud Functions
    }

    match /trending/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin(); // maintained by Cloud Functions
    }

    match /hashtags/{tag} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }


    // ══════════════════════════════════════════════════════════════════════════
    // BETA FEEDBACK
    // ══════════════════════════════════════════════════════════════════════════

    match /betaFeedback/{docId} {
      // Any signed-in user can submit feedback
      allow create: if request.auth != null;
      // Only admins can read feedback
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }


    // ══════════════════════════════════════════════════════════════════════════
    // DEFAULT DENY — catch-all (must be last)
    // ══════════════════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
