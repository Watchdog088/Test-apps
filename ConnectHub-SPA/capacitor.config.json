{
  "appId": "com.lynkapp.app",
  "appName": "LynkApp",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "cleartext": false,
    "allowNavigation": [
      "lynkapp-c7db1.web.app",
      "lynkapp-c7db1.firebaseapp.com",
      "*.lynkapp.com",
      "lynkapp.com",
      "*.firebase.google.com",
      "*.googleapis.com",
      "*.firebaseio.com",
      "*.firebasestorage.googleapis.com",
      "*.stripe.com",
      "*.onesignal.com",
      "*.giphy.com",
      "*.unsplash.com",
      "*.pexels.com",
      "itunes.apple.com",
      "*.itunes.apple.com",
      "podcasts.apple.com",
      "*.deezer.com",
      "api.deezer.com",
      "*.youtube.com",
      "*.googleapis.com",
      "*.ytimg.com",
      "api.rawg.io",
      "*.rawg.io",
      "api.openweathermap.org",
      "api.open-meteo.com",
      "api.ipapi.com",
      "ipapi.co",
      "api.coingecko.com",
      "api.the-guardian.com",
      "hacker-news.firebaseio.com",
      "api.unsplash.com",
      "api.pexels.com",
      "api.dicebear.com",
      "tile.openstreetmap.org",
      "unpkg.com",
      "cdnjs.cloudflare.com",
      "fonts.googleapis.com",
      "fonts.gstatic.com"
    ]
  },
  "ios": {
    "scheme": "LynkApp",
    "contentInset": "automatic",
    "allowsLinkPreview": false,
    "scrollEnabled": true,
    "backgroundColor": "#0a0a18",
    "limitsNavigationsToAppBoundDomains": false,
    "preferredContentMode": "mobile"
  },
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#0a0a18",
    "captureInput": true,
    "webContentsDebuggingEnabled": false,
    "useLegacyBridge": false,
    "minWebViewVersion": 80,
    "loggingBehavior": "none"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2500,
      "launchAutoHide": true,
      "launchFadeOutDuration": 400,
      "backgroundColor": "#0a0a18",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true,
      "iosSpinnerStyle": "small",
      "spinnerColor": "#6366f1"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0a0a18",
      "overlaysWebView": true,
      "androidOverlaysWebView": true
    },
    "NavigationBar": {
      "backgroundColor": "#0a0a18",
      "visible": false
    },
    "Keyboard": {
      "resize": "body",
      "style": "DARK",
      "resizeOnFullScreen": true
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon_config_sample",
      "iconColor": "#6366f1",
      "sound": "beep.wav"
    },
    "Camera": {
      "permissions": ["camera", "photos"]
    },
    "Filesystem": {
      "permissions": ["publicStorage"]
    },
    "Geolocation": {
      "permissions": ["location"]
    },
    "Haptics": {},
    "Share": {},
    "Browser": {
      "androidShowTitle": true
    },
    "App": {
      "launchAutoHide": false
    }
  }
}
