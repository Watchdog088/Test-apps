# ============================================================
# LynkApp — Complete .env.example
# Copy to .env and fill in your real values.
# NEVER commit the actual .env file to Git.
# Updated: June 10, 2026 — Full Beta Launch Checklist
# ============================================================

# ── Firebase (REQUIRED — App will not start without these) ──────────────────
# Firebase Console → Project Settings → Your Apps → SDK Setup & Configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Sentry Error Monitoring (CRITICAL — Add before beta launch) ──────────────
# 1. Sign up free at https://sentry.io
# 2. Create React project → Settings → Client Keys → DSN
# Dashboard: https://sentry.io/organizations/YOUR_ORG/projects/lynkapp-frontend/
VITE_SENTRY_DSN=https://YOUR_KEY@oXXXXXX.ingest.sentry.io/XXXXXXX

# ── Metered.ca TURN Server (CRITICAL — Video calls fail on mobile data without this) ─
# 1. Sign up free at https://dashboard.metered.ca
# 2. Create app "LynkApp" → Credentials → API Key + Username + Password
# Free tier: 500GB/month relay bandwidth
VITE_METERED_API_KEY=your_metered_api_key_here
VITE_TURN_USERNAME=your_metered_turn_username
VITE_TURN_PASSWORD=your_metered_turn_password

# ── OneSignal Push Notifications (IMPORTANT — Week 1) ───────────────────────
# 1. Sign up free at https://onesignal.com
# 2. Create app "LynkApp" → Settings → Keys & IDs → OneSignal App ID
# Free tier: 10,000 subscribers
VITE_ONESIGNAL_APP_ID=your_onesignal_app_id_here

# ── Stripe Payments (IMPORTANT — Keep test mode during beta) ────────────────
# Dashboard: https://dashboard.stripe.com → Developers → API keys
# Use pk_test_ during beta, switch to pk_live_ for production
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# ── Pexels (Free photos & videos — Feed, Stories, Media Hub) ────────────────
# Get key: https://www.pexels.com/api/ → Your API Key
# Free: 200 req/hr | 20,000 req/month
VITE_PEXELS_API_KEY=your_pexels_api_key_here

# ── Unsplash (High-quality photos — Feed, Stories, Backgrounds) ─────────────
# Get key: https://unsplash.com/developers → New Application → Access Key
VITE_UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
VITE_UNSPLASH_APP_ID=your_unsplash_app_id_here

# ── RAWG (Gaming database — Gaming Hub) ─────────────────────────────────────
# Get key: https://rawg.io/apidocs → Sign up → API Key (free, 20k req/month)
VITE_RAWG_API_KEY=your_rawg_api_key_here

# ── Giphy (GIF search — messages, reactions, stories) ───────────────────────
# Get key: https://developers.giphy.com/dashboard/ → Create an App
VITE_GIPHY_API_KEY=your_giphy_api_key_here

# ── News APIs (Trending section) ─────────────────────────────────────────────
# NewsAPI: https://newsapi.org → Get API Key (free: 100 req/day)
VITE_NEWSAPI_KEY=your_newsapi_key_here
# Guardian: https://open-platform.theguardian.com/access/ → Register
VITE_GUARDIAN_API_KEY=your_guardian_api_key_here

# ── YouTube Data API v3 (Videos, trending content) ──────────────────────────
# Google Cloud Console → Enable YouTube Data API v3 → Create API Key
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here

# ── DeepAR (AR Filters — optional, V1.1) ────────────────────────────────────
# Sign up: https://developer.deepar.ai → Create Project → API Key
# Free tier available
VITE_DEEPAR_KEY=your_deepar_key_here

# ── Mailgun (Production email — Week 1) ─────────────────────────────────────
# NOTE: This goes in ConnectHub-Backend/.env, NOT here in frontend .env
# Sign up: https://mailgun.com (free: 1,000 emails/month)
# MAILGUN_API_KEY goes in ConnectHub-Backend/.env only (never expose in frontend)

# ── Ad Network Keys ──────────────────────────────────────────────────────────
# Google AdSense → https://adsense.google.com → Sites → Get Code
VITE_ADSENSE_PUBLISHER_ID=ca-pub-REPLACE_WITH_YOUR_PUBLISHER_ID
VITE_ADSENSE_BANNER_SLOT=REPLACE_WITH_BANNER_AD_UNIT_ID
VITE_ADSENSE_INTER_SLOT=REPLACE_WITH_INTERSTITIAL_AD_UNIT_ID
VITE_ADSENSE_REWARDED_SLOT=REPLACE_WITH_REWARDED_AD_UNIT_ID

# AppLovin MAX → https://dash.applovin.com → Account → Keys
VITE_APPLOVIN_SDK_KEY=REPLACE_WITH_APPLOVIN_SDK_KEY

# IronSource LevelPlay → https://platform.ironsrc.com → SDK → Keys
VITE_IRONSOURCE_APP_KEY=REPLACE_WITH_IRONSOURCE_APP_KEY
