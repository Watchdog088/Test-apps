# Copy this file to .env and fill in your real Firebase values
# Get these from Firebase Console → Project Settings → Your Apps → SDK Setup

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── RAWG (Gaming database — Gaming Hub) ───────────────────────────────────
# Get key: https://rawg.io/apidocs → Sign up → API Key (free, 20k req/month)
VITE_RAWG_API_KEY=your_rawg_api_key_here

# ── Giphy (GIF search — messages, reactions, stories) ─────────────────────
# Get key: https://developers.giphy.com/dashboard/ → Create an App
VITE_GIPHY_API_KEY=your_giphy_api_key_here

# Optional 3rd-party API keys
VITE_NEWSAPI_KEY=your_newsapi_key
VITE_YOUTUBE_API_KEY=your_youtube_key
VITE_ONESIGNAL_APP_ID=your_onesignal_id

# ── Ad Network Keys ────────────────────────────────────────────────────────
# Google AdSense  →  https://adsense.google.com  → Sites → Get Code
VITE_ADSENSE_PUBLISHER_ID=ca-pub-REPLACE_WITH_YOUR_PUBLISHER_ID
VITE_ADSENSE_BANNER_SLOT=REPLACE_WITH_BANNER_AD_UNIT_ID
VITE_ADSENSE_INTER_SLOT=REPLACE_WITH_INTERSTITIAL_AD_UNIT_ID
VITE_ADSENSE_REWARDED_SLOT=REPLACE_WITH_REWARDED_AD_UNIT_ID

# AppLovin MAX  →  https://dash.applovin.com  → Account → Keys
VITE_APPLOVIN_SDK_KEY=REPLACE_WITH_APPLOVIN_SDK_KEY

# IronSource LevelPlay  →  https://platform.ironsrc.com  → SDK → Keys
VITE_IRONSOURCE_APP_KEY=REPLACE_WITH_IRONSOURCE_APP_KEY
