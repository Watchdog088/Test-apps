                <div class="toggle-container">
                    <div>
                        <div class="list-item-title">End-to-End Encryption</div>
                        <div class="list-item-subtitle">Secure all calls</div>
                    </div>
                    <div class="toggle-switch active" onclick="toggleSwitch(this)">
