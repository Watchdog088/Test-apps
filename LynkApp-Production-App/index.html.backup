                        <div class="stat-label">Avg Duration</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value">98%</div>
                        <div class="stat-label">Success Rate</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value">Excellent</div>
                        <div class="stat-label">Avg Quality</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value">12</div>
                        <div class="stat-label">Contacts</div>
                    </div>
                </div>

                <div class="section-header">
                    <div class="section-title">Call Quality Breakdown</div>
                </div>

                <div class="list-item">
                    <div class="list-item-icon">âœ…</div>
                    <div class="list-item-content">
                        <div class="list-item-title">Excellent Quality</div>
                        <div class="list-item-subtitle">18 calls (78%)</div>
                    </div>
                </div>

                <div class="list-item">
                    <div class="list-item-icon">âš ï¸</div>
                    <div class="list-item-content">
                        <div class="list-item-title">Good Quality</div>
                        <div class="list-item-subtitle">4 calls (17%)</div>
                    </div>
                </div>

                <div class="list-item">
                    <div class="list-item-icon">âŒ</div>
                    <div class="list-item-content">
                        <div class="list-item-title">Poor Quality</div>
                        <div class="list-item-subtitle">1 call (5%)</div>
                    </div>
                </div>

                <button class="btn" style="background: var(--glass);" onclick="exportCallAnalytics()">ðŸ“Š Export Report</button>
            </div>
        </div>

        <!-- 9. Call Settings Modal -->
        <div id="callSettingsModal" class="modal">
            <div class="modal-header">
                <div class="modal-close" onclick="closeModal('callSettings')">âœ•</div>
                <div class="modal-title">ðŸ”§ Call Settings</div>
            </div>
            <div class="modal-content">
                <div style="text-align: center; margin: 30px 0;">
                    <div style="font-size: 64px; margin-bottom: 16px;">ðŸ”§</div>
                    <div style="font-size: 18px; font-weight: 600; margin-bottom: 8px;">Call Configuration</div>
                    <div style="font-size: 14px; color: var(--text-secondary);">Customize your calling experience</div>
                </div>

                <div class="section-header">
                    <div class="section-title">Video Settings</div>
                </div>

                <div class="list-item" onclick="selectVideoResolution()">
                    <div class="list-item-icon">ðŸ“¹</div>
                    <div class="list-item-content">
                        <div class="list-item-title">Video Resolution</div>
                        <div class="list-item-subtitle">720p HD</div>
                    </div>
                    <div class="list-item-arrow">â†’</div>
                </div>

                <div class="toggle-container">
                    <div>
                        <div class="list-item-title">HD Video</div>
                        <div class="list-item-subtitle">Better quality, uses more data</div>
                    </div>
                    <div class="toggle-switch active" onclick="toggleSwitch(this)">
                        <div class="toggle-slider"></div>
                    </div>
                </div>

                <div class="toggle-container">
                    <div>
                        <div class="list-item-title">Mirror My Video</div>
                        <div class="list-item-subtitle">Flip camera feed horizontally</div>
                    </div>
                    <div class="toggle-switch active" onclick="toggleSwitch(this)">
                        <div class="toggle-slider"></div>
                    </div>
                </div>

                <div class="section-header">
                    <div class="section-title">Call Behavior</div>
                </div>

                <div class="toggle-container">
                    <div>
                        <div class="list-item-title">Always Use Speaker</div>
                        <div class="list-item-subtitle">Default to speakerphone</div>
                    </div>
                    <div class="toggle-switch" onclick="toggleSwitch(this)">
                        <div class="toggle-slider"></div>
                    </div>
                </div>

                <div class="toggle-container">
                    <div>
                        <div class="list-item-title">Start with Video Off</div>
                        <div class="list-item-subtitle">Begin calls with camera disabled</div>
                    </div>
                    <div class="toggle-switch" onclick="toggleSwitch(this)">
                        <div class="toggle-slider"></div>
                    </div>
                </div>

                <div class="toggle-container">
                    <div>
                        <div class="list-item-title">Start with Audio Off</div>
                        <div class="list-item-subtitle">Begin calls muted</div>
                    </div>
                    <div class="toggle-switch" onclick="toggleSwitch(this)">
