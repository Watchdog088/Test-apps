                        <div class="list-item-subtitle">Home Network â€¢ Excellent signal</div>
                    </div>
                    <div style="padding: 4px 12px; background: rgba(16, 185, 129, 0.2); border-radius: 12px; font-size: 11px; font-weight: 700; color: var(--success);">
                        CONNECTED
                    </div>
                </div>

                <div class="section-header">
                    <div class="section-title">Recommendations</div>
                </div>

                <div style="background: var(--glass); border: 1px solid var(--glass-border); border-radius: 12px; padding: 16px; margin-bottom: 16px;">
                    <div style="font-size: 14px; font-weight: 600; margin-bottom: 8px; color: var(--success);">âœ“ Network is Optimal</div>
                    <div style="font-size: 13px; color: var(--text-secondary); line-height: 1.6;">
                        â€¢ Excellent connection for HD calls<br>
                        â€¢ No action needed<br>
                        â€¢ Recommended for group calls
                    </div>
                </div>

                <div class="toggle-container">
                    <div>
                        <div class="list-item-title">Data Saver Mode</div>
                        <div class="list-item-subtitle">Reduce data usage</div>
                    </div>
                    <div class="toggle-switch" onclick="toggleSwitch(this)">
                        <div class="toggle-slider"></div>
                    </div>
                </div>

                <button class="btn" onclick="runNetworkTest()">ðŸ” Run Speed Test</button>
            </div>
        </div>

        <!-- Call Details Modal (Additional Support) -->
        <div id="callDetailsModal" class="modal">
            <div class="modal-header">
                <div class="modal-close" onclick="closeModal('callDetails')">âœ•</div>
