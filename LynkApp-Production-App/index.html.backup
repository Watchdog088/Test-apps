                </div>

                <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px;">
                    <button class="btn" onclick="callBackContact('[User Name]', 'video')">ðŸ“¹ Call Again</button>
                    <button class="btn" style="background: var(--glass);" onclick="deleteCallFromHistory('[User Name]')">ðŸ—‘ï¸ Delete</button>
                </div>
            </div>
        </div>

