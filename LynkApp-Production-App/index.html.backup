<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="description" content="LynkApp - Connect, Share, and Discover. The ultimate social platform for meaningful connections.">
    <meta name="theme-color" content="#4f46e5">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="LynkApp">
    
    <!-- Open Graph / Social Sharing -->
    <meta property="og:type" content="website">
    <meta property="og:title" content="LynkApp - Connect, Share, Discover">
    <meta property="og:description" content="The ultimate social platform for meaningful connections.">
    <meta property="og:url" content="https://lynkapp.com">
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="LynkApp">
    <meta name="twitter:description" content="Connect, Share, and Discover.">
    
    <!-- Security -->
    <meta http-equiv="X-Content-Type-Options" content="nosniff">
    <meta http-equiv="X-Frame-Options" content="DENY">
    <meta name="referrer" content="strict-origin-when-cross-origin">
    
    <title>LynkApp - Connect, Share, Discover</title>
    
    <!-- External CSS -->
    <link rel="stylesheet" href="css/lynkapp-main.css">
    
    <!-- PWA -->
    <link rel="manifest" href="manifest.json">
    <link rel="apple-touch-icon" href="icons/icon-192.png">
    
    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://firebaseio.com">
    <link rel="preconnect" href="https://googleapis.com">
    <link rel="dns-prefetch" href="https://firebaseio.com">
</head>
<body>
    <!-- SPLASH SCREEN -->
    <div class="splash-screen" id="splashScreen">
        <div class="splash-logo">ðŸ”—</div>
        <div class="splash-app-name">Lynkapp</div>
        <div class="splash-tagline">Connect â€¢ Share â€¢ Discover</div>
        <div class="splash-loader"></div>
        <div class="splash-version">Version 2.5.1</div>
    </div>
    <!-- ISOLATED: Force splash â†’ login after 3s regardless of any JS errors elsewhere -->



    <!-- ================================================
         LYNKAPP LOGIN SYSTEM v2 - Self-contained & Reliable
         ================================================ -->

    <!-- LOGIN SCREEN -->
    <div class="login-container hidden" id="loginScreen">
        <div class="login-logo-section">
            <div class="login-logo-box">ðŸ”—</div>
            <div class="login-app-name">Lynkapp</div>
            <div class="login-tagline">Connect â€¢ Share â€¢ Discover</div>
        </div>

        <!-- Tab Switcher -->
        <div class="login-tabs">
            <div class="login-tab active" onclick="switchLoginTab('login')">Sign In</div>
            <div class="login-tab" onclick="switchLoginTab('register')">Sign Up</div>
        </div>

        <!-- Login Form -->
        <div class="login-form active" id="loginForm">
            <div class="input-group">
                <div class="input-wrapper">
                    <span class="input-icon">ðŸ“§</span>
                    <input type="email" class="input-field-login" placeholder="Email address" id="loginEmail">
                </div>
            </div>

            <div class="input-group">
                <div class="input-wrapper">
                    <span class="input-icon">ðŸ”’</span>
                    <input type="password" class="input-field-login" placeholder="Password" id="loginPassword">
                    <span class="input-toggle" onclick="togglePasswordVisibility('loginPassword')">ðŸ‘ï¸</span>
                </div>
            </div>

            <div class="options-row">
                <div class="checkbox-wrapper" onclick="toggleCheckboxLogin('rememberMe')">
                    <div class="checkbox" id="rememberMe"></div>
                    <span class="checkbox-label">Remember me</span>
                </div>
                <span class="forgot-link" onclick="handleForgotPassword()">Forgot password?</span>
            </div>

            
            <!-- Inline error message -->
            <div id="loginErrorMsg" style="display:none;background:rgba(255,50,50,0.15);border:1px solid rgba(255,100,100,0.4);color:#ff8080;padding:10px 16px;border-radius:12px;font-size:13px;text-align:center;margin-bottom:8px;"></div>
            <button class="login-button" onclick="handleLogin()">Sign In</button>
                <div style="text-align:center; margin-top: 16px;">
                    <button onclick="demoLogin()" style="background: transparent; border: 1px solid rgba(255,255,255,0.3); color: rgba(255,255,255,0.7); padding: 10px 24px; border-radius: 20px; font-size: 14px; cursor: pointer; width: 100%;">
                        👁️ View Demo (Skip Login)
                    </button>
                    <p style="color: rgba(255,255,255,0.4); font-size: 11px; margin-top: 8px;">For review purposes only</p>
                </div>
        </div>

        <!-- Register Form -->
        <div class="login-form" id="registerForm">
            <div class="input-row">
                <div class="input-group">
                    <div class="input-wrapper">
                        <span class="input-icon">ðŸ‘¤</span>
                        <input type="text" class="input-field-login" placeholder="First name" id="registerFirstName">
                    </div>
                </div>
                <div class="input-group">
                    <div class="input-wrapper">
                        <span class="input-icon">ðŸ‘¤</span>
                        <input type="text" class="input-field-login" placeholder="Last name" id="registerLastName">
                    </div>
                </div>
            </div>

            <div class="input-group">
                <div class="input-wrapper">
                    <span class="input-icon">@</span>
                    <input type="text" class="input-field-login" placeholder="Username" id="registerUsername">
                </div>
            </div>

            <div class="input-group">
                <div class="input-wrapper">
                    <span class="input-icon">ðŸ“§</span>
                    <input type="email" class="input-field-login" placeholder="Email address" id="registerEmail">
                </div>
            </div>

            <div class="input-group">
                <div class="input-wrapper">
                    <span class="input-icon">ðŸ”’</span>
                    <input type="password" class="input-field-login" placeholder="Password" id="registerPassword">
                    <span class="input-toggle" onclick="togglePasswordVisibility('registerPassword')">ðŸ‘ï¸</span>
                </div>
            </div>

            <div class="input-group">
                <div class="input-wrapper">
                    <span class="input-icon">ðŸ”’</span>
                    <input type="password" class="input-field-login" placeholder="Confirm password" id="registerConfirmPassword">
                </div>
            </div>

            <div class="preferences-section">
                <div class="preferences-title">Account Preferences</div>
                <div class="feature-toggle">
                    <div class="checkbox checked" id="datingEnabled" onclick="toggleCheckboxLogin('datingEnabled')"></div>
                    <div class="feature-info">
                        <div class="feature-title">Enable Dating Features</div>
                        <div class="feature-description">Access matching, dating profiles, and find meaningful connections</div>
                    </div>
                </div>
            </div>

            <button class="login-button" onclick="handleRegister()">Create Account</button>
        </div>

        <!-- Social Login -->
