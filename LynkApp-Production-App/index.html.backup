        <!-- Photo Verification Modal (Complete) -->
        <div id="photoVerificationModal" class="modal">
            <div class="modal-header">
                <div class="modal-close" onclick="closeModal('photoVerification')">âœ•</div>
                <div class="modal-title">ðŸ“¸ Photo Verification</div>
            </div>
            <div class="modal-content">
                <div style="text-align: center; margin: 30px 0;">
                    <div style="font-size: 64px; margin-bottom: 16px;">âœ“</div>
                    <div style="font-size: 18px; font-weight: 600; margin-bottom: 8px;">Verify Your Photos</div>
                    <div style="font-size: 14px; color: var(--text-secondary);">Build trust with verified photos</div>
                </div>
                
                <div style="background: linear-gradient(135deg, var(--success), var(--primary)); padding: 20px; border-radius: 16px; text-align: center; margin-bottom: 20px;">
                    <div style="font-size: 14px; opacity: 0.9; margin-bottom: 8px;">Verification Status</div>
                    <div style="font-size: 32px; font-weight: 800; margin-bottom: 8px;">âœ“ Verified</div>
                    <div style="font-size: 13px; opacity: 0.9;">Verified on Jan 15, 2024</div>
                </div>
                
                <div class="section-header">
                    <div class="section-title">Why Verify?</div>
                </div>
                
                <div style="background: var(--glass); border: 1px solid var(--glass-border); border-radius: 12px; padding: 16px; margin-bottom: 16px;">
                    <div style="font-size: 14px; color: var(--text-secondary); line-height: 1.8;">
                        âœ“ Build trust with potential matches<br>
                        âœ“ Get 3x more profile views<br>
                        âœ“ Stand out from the crowd<br>
                        âœ“ Increase match quality<br>
                        âœ“ Show you're authentic
                    </div>
                </div>
                
                <div class="section-header">
                    <div class="section-title">Verified Photos</div>
                    <div class="section-link">3 verified</div>
                </div>
                
                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 16px;">
                    <div style="aspect-ratio: 1; background: linear-gradient(135deg, var(--primary), var(--secondary)); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 32px; position: relative; border: 2px solid var(--success);">
                        ðŸ‘¤
                        <div style="position: absolute; bottom: 6px; right: 6px; width: 24px; height: 24px; border-radius: 50%; background: var(--success); border: 2px solid white; display: flex; align-items: center; justify-content: center; font-size: 12px;">âœ“</div>
                    </div>
                    <div style="aspect-ratio: 1; background: linear-gradient(135deg, var(--success), var(--accent)); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 32px; position: relative; border: 2px solid var(--success);">
                        ðŸ˜Š
                        <div style="position: absolute; bottom: 6px; right: 6px; width: 24px; height: 24px; border-radius: 50%; background: var(--success); border: 2px solid white; display: flex; align-items: center; justify-content: center; font-size: 12px;">âœ“</div>
                    </div>
                    <div style="aspect-ratio: 1; background: linear-gradient(135deg, var(--warning), var(--error)); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 32px; position: relative; border: 2px solid var(--success);">
                        ðŸ”ï¸
                        <div style="position: absolute; bottom: 6px; right: 6px; width: 24px; height: 24px; border-radius: 50%; background: var(--success); border: 2px solid white; display: flex; align-items: center; justify-content: center; font-size: 12px;">âœ“</div>
                    </div>
                </div>
                
                <button class="btn" onclick="addNewVerifiedPhoto()">
                    ðŸ“· Add New Photo to Verify
                </button>
                
                <div style="background: var(--glass); border: 1px solid var(--glass-border); border-radius: 12px; padding: 16px; margin-top: 20px;">
                    <div style="font-size: 14px; font-weight: 600; margin-bottom: 8px;">ðŸ’¡ How It Works</div>
                    <div style="font-size: 13px; color: var(--text-secondary); line-height: 1.6;">
                        1. Upload a clear photo of yourself<br>
                        2. Take a selfie matching the pose shown<br>
                        3. Our system verifies it's really you<br>
                        4. Get the verified badge!
                    </div>
                </div>
            </div>
        </div>
        
